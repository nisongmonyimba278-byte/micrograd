# .gitignore for micrograd

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.dylib

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
venv/
env/
.venv/

# Conda environments (if stored locally)
conda-env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# pytest cache
.pytest_cache/

# DOLFINx / FEniCSx generated output
*.bp/
*.xdmf
*.h5

# Gmsh temporary files
temp_*.msh

# Output directories (generated by pipeline)
output/
figures/
uq/
pareto/
scalability/
convergence_study/
filter_sensitivity/
validation/
3d_validation/

# Documentation builds
docs/_build/

# LaTeX auxiliary files
*.aux
*.log
*.bbl
*.blg
*.toc
*.out
*.lof
*.lot

# PDFs (keep only the compiled manuscript)
*.pdf
!manuscript/manuscript.pdf

# OS files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/